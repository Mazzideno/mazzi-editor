{
  "manifest_version": 3,
  "name": "MazziGroup Post Editor",
  "short_name": "MazziEditor",
  "description": "Offline Post Editor by Mazzideno",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#0A0A0A",
  "theme_color": "#FF5700",
  "orientation": "portrait",
  "icons": [
    { "src": "logo.png", "sizes": "192x192", "type": "image/png" },
    { "src": "logo.png", "sizes": "512x512", "type": "image/png" }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MazziGroup Post Editor",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "permissions": ["storage", "activeTab"]
}
